# Rooted Revival Pinning Service Configuration

# Service port
PIN_SERVICE_PORT=3000

# IPFS node configuration
IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY_URL=http://127.0.0.1:8080

# Cloudflare configuration (for DNSLink updates)
CF_EMAIL=your-cloudflare-email
CF_API_KEY=your-cloudflare-api-key
CF_ZONE_ID=your-cloudflare-zone-id
CF_WEB3_HOSTNAME_ID=your-web3-hostname-id

# Authentication token for API access
AUTH_TOKEN=generate-a-secure-token-here

# Data directory for pin database
DATA_DIR=./data
